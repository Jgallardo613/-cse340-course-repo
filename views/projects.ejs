<%- include('partials/header') %>

<h1><%= title %></h1>

<% if (projects && projects.length > 0) { %>
  <div style="display: grid; gap: 20px;">
    <% projects.forEach(project => { %>
      <div style="background: #f8f9fa; border-left: 5px solid #007bff; border-radius: 8px; padding: 20px; box-shadow: 2px 2px 5px rgba(0,0,0,0.1);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
          <h3 style="margin: 0; color: #007bff;"><%= project.title %></h3>
          <span style="background: #28a745; color: white; padding: 5px 10px; border-radius: 20px; font-size: 14px;">
            <%= project.organization_name %>
          </span>
        </div>
        
        <p style="color: #6c757d; margin: 10px 0;">
          📅 <%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </p>
        
        <p style="margin: 10px 0;"><%= project.description %></p>
        
        <p style="margin: 10px 0 0 0;">
          📍 <strong>Location:</strong> <%= project.location %>
        </p>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <p>No projects found.</p>
<% } %>

<%- include('partials/footer') %>