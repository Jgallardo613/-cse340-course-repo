<%- include('partials/header') %>
<h1><%= title %></h1>
<% if (projects && projects.length > 0) { %>
  <div style="display: grid; gap: 20px;">
    <% projects.forEach(project => { %>
      <div style="background: #f8f9fa; border-left: 5px solid #007bff; border-radius: 8px; padding: 20px; box-shadow: 2px 2px 5px rgba(0,0,0,0.1);">
        <p style="font-size: 1.1rem; margin: 0;">
          <strong><%= new Date(project.project_date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>: <%= project.title %></strong> (<em><%= project.organization_name %></em>)
        </p>
      </div>
    <% }) %>
  </div>
<% } else { %>
  <p>No projects found.</p>
<% } %>
<%- include('partials/footer') %>
